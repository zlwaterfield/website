.intro-message
  width:100%
  height: 100%
  color: #757575
  text-align:center
  transition: 0.4s ease-in-out

  .intro-message-top
    margin: auto
    opacity: 0
    z-index:10
    padding-top:150px
    max-width: 650px

    h1
      font-size: 50px

    h2
      font-size: 32px

    h4
      font-size: 20px
      margin-top: 25px
      line-height: 32px

    a
      text-decoration: underline
      color: rgb(114, 114, 114)

.error_404
  width: 100%
  height: 100%
  padding-top: 60px
  background: url('../../images/forest.gif') no-repeat center center fixed
  -webkit-background-size: cover
  position: fixed

  .error_container
    img
      position: absolute
      right: 0
      bottom: 0
      width: 75%
      max-width: 700px

    a
      color: white

    .error_bubble
      position: absolute
      top: 45%
      text-align: center
      z-index: 100
      width: 100%

      div
        color: white
        font-weight: 300
        font-size: 3em
