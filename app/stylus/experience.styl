.experience-container
  height: 2500px
  width: 100%

  .hidden-message
    position: fixed
    margin-left: auto
    margin-left: auto
    right:0
    left: 0
    bottom: calc(50% - 50px)
    font-weight: 300
    font-size: 1.5em
    z-index: 1

  .card
    margin: 0
    transition: 0.5s ease-in-out
    position: fixed
    background-color: #F7F9F9
    box-shadow: 0px 0px 13px 0px rgba(0, 0, 0, 0.11)
    height: 500px
    width: 550px
    margin-left: -moz-calc(50% - 275px)
    margin-left: calc(50% - 275px)
    left: 0
    bottom: calc(50% - 250px)

    .card-header
      height: 50px
      width: 100%
      padding: 18px
      background-color: white
      -moz-box-sizing: border-box
      box-sizing: border-box

      .card-btn
        display: inline-block
        vertical-align: top
        height: 13px
        width: 13px
        border-radius: 50%
        margin: 0 5px
        float: left

        &.btn-close
          background-color: #FF9375

        &.btn-minimize
          background-color: #FFCB7A

        &.btn-open
          background-color: #70DACD

    .card-body
      padding: 10px
      text-align: left

      h2, h3
        margin: 5px
        font-weight: 300

      h2
        font-size: 1.5em

      h3
        font-size: 0.9em

      .description
        margin: 5px
        margin-top: 15px

        p
          font-weight: 300
          font-size: 1.2em
          margin: 0

    .card-footer
      position: absolute
      bottom: 0
      text-align: center
      width: 100%
      height: 50px
      cursor: pointer
      -webkit-touch-callout: none; /* iOS Safari */
      -webkit-user-select: none; /* Chrome/Safari/Opera */
      -khtml-user-select: none; /* Konqueror */
      -moz-user-select: none; /* Firefox */
      -ms-user-select: none; /* Internet Explorer/Edge */
      user-select: none; /* Non-prefixed version, currently */

      &.next
        right: 0

      // &.prev
        // left: 0

      &:hover
        background: darken(whitesmoke, 5%)

        h4
          color: darken(whitesmoke, 50%)

      h4
        display: inline-block
        font-size: 1.8em
        font-weight: 300
        color: darken(whitesmoke, 25%)

  .reset
    position: absolute
    bottom: 20px
    right: 20px
    cursor: pointer
    background-color: #F7F9F9
    color: darken(whitesmoke, 25%)
    border: 0
    font-weigh5: 300
    font-size: 1.5em
    padding: 10px
    border-radius: 3px
    outline: none

.fly-out
  transform: scale(1.15) translate3d(0, 60px, 0) !important
  display: none
  z-index: 1000 !important
