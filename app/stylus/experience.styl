.experience-container
  height: 2500px
  width: 100%

  .card
    margin: 0
    transition: 0.8s ease-in-out
    position: fixed
    background-color: #F7F9F9
    box-shadow: 0px 0px 13px 0px rgba(0, 0, 0, 0.11)
    height: 450px
    width: 500px
    margin-left: -moz-calc(50% - 250px)
    margin-left: calc(50% - 250px)
    left: 0
    bottom: calc(50% - 225px)

    .header
      height: 50px
      width: 100%
      padding: 18px
      background-color: white
      -moz-box-sizing: border-box
      box-sizing: border-box

      .card-btn
        display: inline-block
        vertical-align: top
        height: 13px
        width: 13px
        border-radius: 50%
        margin: 0 5px
        float: left

        &.btn-close
          background-color: #FF9375

        &.btn-minimize
          background-color: #FFCB7A

        &.btn-open
          background-color: #70DACD

    &.job0
      z-index: 5

    &.job1
      transform: scale(0.93) translate3d(0, -35px, 0)
      z-index: 4

.arrow
  width: 50px
  height: 50px
  position:relative
  vertical-align: middle
  margin-top: 60px

  &.prev
    float: left
    transform: rotate(90deg)

  &.next
    float: right
    transform: rotate(-90deg)

  &:after, &:before
    content:''
    width:0
    height:0
    border-style:solid
    border-color:transparent
    border-left-width: 15px
    border-right-width: 15px
    border-top-width:10px
    position:absolute
    left:10px

  &:before
    border-top-color: darken(whitesmoke, 25%)
    top:15px

  &:after
    border-top-color: whitesmoke
    top:14px

.fly-out
  transform: scale(1.15) translate3d(0, 60px, 0) !important
  opacity: 0 !important
  z-index: 4 !important

.fly-in
  transform: scale(1) translate3d(0, 0, 0) !important
  z-index: 5 !important
