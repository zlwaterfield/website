.shake-slow {
  display: inline-block;
  transform-origin: center center; }

@keyframes shake-slow {
  4% { transform: translate(0, -2px) rotate(-1.5deg) }

  8% { transform: translate(0, -2px) rotate(-2deg) }

  12% { transform: translate(0, -1.5px) rotate(2deg) }

  16% { transform: translate(0, -1.5px) rotate(-2deg) }

  20% { transform: translate(0, -2px) rotate(2deg) }

  24% { transform: translate(0, 2px) rotate(2deg) }

  28% { transform: translate(0, 0.5px) rotate(2deg) }

  32% { transform: translate(0, 2px) rotate(-1.5deg) }

  36% { transform: translate(0, -2px) rotate(2deg) }

  40% { transform: translate(0, -1.5px) rotate(2deg) }

  44% { transform: translate(0, 2px) rotate(0.5deg) }

  48% { transform: translate(0, -1.5px) rotate(0.5deg) }

  52% { transform: translate(0, 2px) rotate(2deg) }

  56% { transform: translate(0, 2px) rotate(2deg) }

  60% { transform: translate(0, 2px) rotate(2deg) }

  64% { transform: translate(0, -1.5px) rotate(2deg) }

  68% { transform: translate(0, -2px) rotate(-1.5deg) }

  72% { transform: translate(0, 2px) rotate(2deg) }

  76% { transform: translate(0, -1.5px) rotate(2deg) }

  80% { transform: translate(0, 2px) rotate(2deg) }

  84% { transform: translate(0, 2px) rotate(2deg) }

  88% { transform: translate(0, -1.5px) rotate(2deg) }

  92% { transform: translate(0, 0.5px) rotate(-1.5deg) }

  96% { transform: translate(0, -1.5px) rotate(2deg) }

  0%, 100% { transform: translate(0, 0) rotate(0) }
}

.shake-slow.shake:hover {
  animation-name: shake-slow;
  animation-duration: 5s;
  animation-timing-function: ease-in-out;
  animation-iteration-count: infinite; }
